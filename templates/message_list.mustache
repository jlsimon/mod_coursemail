{{!
    @template mod_coursemail/message_list

    Renders a list of folder items (conversations or messages).

    Context variables required for this template:
    * items - Array of folder items
    * hasitems - Whether there is at least one item
    * hasmore - Whether a further page of items can be loaded

    Example context (json):
    {
        "hasitems": true,
        "hasmore": false,
        "items": [
            {
                "conversationid": 5,
                "messageid": 9,
                "subject": "Welcome",
                "preview": "Hello class...",
                "fromname": "Teacher One",
                "recipientname": "Student One",
                "recipientextra": 2,
                "sourcecmid": 42,
                "activityname": "Topic 1 mail",
                "timeformatted": "1 Jan 2026",
                "unread": true,
                "unreadcount": 2,
                "starred": false,
                "draft": false
            }
        ]
    }
}}
<div class="coursemail-message-list list-group" data-region="message-list">
    {{#hasitems}}
        {{#items}}
            <div class="coursemail-item-row d-flex align-items-stretch">
            {{! Selection checkbox; only visible when the list is selectable (JS adds the class). }}
            <label class="coursemail-item-check align-items-center px-2 m-0">
                <input type="checkbox" class="coursemail-check" data-action="select-item"
                       data-conversationid="{{conversationid}}"
                       aria-label="{{#str}}selectconversation, coursemail{{/str}}">
            </label>
            <button type="button"
                    class="list-group-item list-group-item-action coursemail-item flex-grow-1 {{#unread}}font-weight-bold{{/unread}}"
                    data-action="open-item"
                    data-conversationid="{{conversationid}}"
                    data-messageid="{{messageid}}"
                    data-sourcecmid="{{sourcecmid}}"
                    data-draft="{{#draft}}1{{/draft}}{{^draft}}0{{/draft}}">
                <div class="d-flex w-100 justify-content-between">
                    <span class="coursemail-from">
                        {{#starred}}<i class="icon fa fa-star text-warning" aria-hidden="true"></i>{{/starred}}
                        {{! Sent items label the addressee ("To: Name +N"); other folders show the author. }}
                        {{#recipientname}}{{#str}}to, coursemail{{/str}}: {{recipientname}}{{#recipientextra}} <span class="text-muted font-weight-normal">+{{recipientextra}}</span>{{/recipientextra}}{{/recipientname}}
                        {{^recipientname}}{{fromname}}{{/recipientname}}
                        {{#draft}}<span class="badge badge-secondary">{{#str}}drafts, coursemail{{/str}}</span>{{/draft}}
                    </span>
                    <small class="text-muted coursemail-date">{{timeformatted}}</small>
                </div>
                <div class="coursemail-subject">{{subject}}</div>
                {{! In the unified course view, label which activity the item belongs to. }}
                {{#activityname}}<div class="coursemail-activity"><span class="badge badge-light border font-weight-normal"><i class="icon fa fa-graduation-cap m-0 mr-1" aria-hidden="true"></i>{{activityname}}</span></div>{{/activityname}}
                <div class="coursemail-preview text-muted small">
                    {{preview}}
                    {{#unreadcount}}<span class="badge badge-primary ml-1">{{unreadcount}}</span>{{/unreadcount}}
                </div>
            </button>
            </div>
        {{/items}}
    {{/hasitems}}
    {{^hasitems}}
        <div class="text-muted p-3" data-region="empty">{{#str}}nomessages, coursemail{{/str}}</div>
    {{/hasitems}}
    {{#hasmore}}
        <div class="text-center p-2" data-region="loadmore">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-action="loadmore">
                {{#str}}loadmore, coursemail{{/str}}
            </button>
        </div>
    {{/hasmore}}
</div>
