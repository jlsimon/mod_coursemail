{{!
    @template mod_coursemail/help

    Help screen shown in the reading pane. The body differs by role: staff (isstaff)
    get the teacher-oriented text, everyone else the student-oriented text. The Back
    button reuses the shared data-action="back" handler to return to the mailbox.

    Context variables required for this template:
    * isstaff - Whether the current user can send (staff) and so sees the teacher text.

    Example context (json):
    {
        "isstaff": false
    }
}}
<div class="coursemail-help p-3" data-region="help">
    <div class="mb-2">
        <button type="button" class="btn btn-sm btn-link pl-0" data-action="back">
            <i class="icon fa fa-arrow-left m-0 mr-1" aria-hidden="true"></i>{{#str}}helpback, coursemail{{/str}}
        </button>
    </div>
    <h3 class="h5">{{#str}}helptitle, coursemail{{/str}}</h3>
    <p class="text-muted">{{#str}}helpintro, coursemail{{/str}}</p>
    {{#isstaff}}
        <h4 class="h6 mt-3">{{#str}}helpabout, coursemail{{/str}}</h4>
        <p>{{#str}}helpteacherabout, coursemail{{/str}}</p>
        <h4 class="h6 mt-3">{{#str}}helpuse, coursemail{{/str}}</h4>
        {{#str}}helpteacheruse, coursemail{{/str}}
        <h4 class="h6 mt-3">{{#str}}helpbenefits, coursemail{{/str}}</h4>
        {{#str}}helpteacherbenefits, coursemail{{/str}}
    {{/isstaff}}
    {{^isstaff}}
        <h4 class="h6 mt-3">{{#str}}helpabout, coursemail{{/str}}</h4>
        <p>{{#str}}helpstudentabout, coursemail{{/str}}</p>
        <h4 class="h6 mt-3">{{#str}}helpuse, coursemail{{/str}}</h4>
        {{#str}}helpstudentuse, coursemail{{/str}}
        <h4 class="h6 mt-3">{{#str}}helpbenefits, coursemail{{/str}}</h4>
        {{#str}}helpstudentbenefits, coursemail{{/str}}
    {{/isstaff}}
</div>
