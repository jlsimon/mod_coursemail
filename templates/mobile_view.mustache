{{!
    @template mod_coursemail/mobile_view

    Minimal Moodle Mobile app view: the activity description and a button to open
    the full mailbox in the browser. Rendered server-side; Ionic/Angular directives
    are interpreted by the app. The "intro" field is provided via otherdata.

    Context variables required for this template:
    * name - Activity name
    * cmid - Course module id
    * url - Browser URL of the activity
}}
<ion-card>
    <ion-card-header>
        <ion-card-title>{{name}}</ion-card-title>
    </ion-card-header>
    <ion-card-content>
        <core-format-text [text]="intro" contextLevel="module" [contextInstanceId]="{{cmid}}"></core-format-text>
    </ion-card-content>
</ion-card>
<ion-button expand="block" core-link [href]="'{{url}}'" [showBrowserWarning]="false">
    {{ 'plugin.mod_coursemail.openinbrowser' | translate }}
</ion-button>
